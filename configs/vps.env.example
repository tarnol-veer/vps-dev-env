# Copy to configs/vps.env and fill locally.
# Do not commit configs/vps.env.

OPENAI_API_KEY=
OPENROUTER_API_KEY=

GITHUB_USERNAME=
GIT_NAME=
GIT_EMAIL=

MEMORY_REPO=owner/project-memory
CORE_REPO=owner/project-core
PLAYGROUND_REPO=

# Optional.
# If empty, ADE uses the sudo caller or current user.
# Set this only when you intentionally want a dedicated install user.
AGENT_USER=

# Optional path overrides.
# If empty, paths are derived from the selected user's home directory.
DEV_ROOT=
REPOS_DIR=
TOOLS_DIR=
CACHE_DIR=
LOGS_DIR=
